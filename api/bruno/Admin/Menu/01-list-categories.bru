meta {
  name: List categories
  type: http
  seq: 1
  tags: [
    admin
  ]
}

get {
  url: {{baseUrl}}/api/admin/categories
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

script:post-response {
  const body = res.getBody();

  if (res.getStatus() === 200 && Array.isArray(body) && body.length > 0) {
    const category = body.find(item => item.name === "Burgers") || body[0];
    bru.setEnvVar("categoryId", category.id);
  }
}
