meta {
  name: Toggle menu item availability (manual)
  type: http
  seq: 81
  tags: [
    admin
    manual
  ]
}

patch {
  url: {{baseUrl}}/api/admin/menu-items/{{baseMenuItemId}}/availability
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}


body:json {
  {
    "available": false
  }
}
