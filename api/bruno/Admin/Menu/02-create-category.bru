meta {
  name: Create category
  type: http
  seq: 2
  tags: [
    admin
    smoke
  ]
}

post {
  url: {{baseUrl}}/api/admin/categories
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}


body:json {
  {
    "name": "Burgers",
    "hasMenu": true
  }
}

script:post-response {
  const body = res.getBody();

  if (res.getStatus() === 201) {
    bru.setEnvVar("categoryId", body.id);
  }
}
