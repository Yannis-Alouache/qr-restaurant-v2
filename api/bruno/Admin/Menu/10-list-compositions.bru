meta {
  name: List compositions
  type: http
  seq: 10
  tags: [
    admin
  ]
}

get {
  url: {{baseUrl}}/api/admin/compositions
  auth: none
}


script:post-response {
  const body = res.getBody();

  if (res.getStatus() === 200 && Array.isArray(body) && body.length > 0) {
    bru.setEnvVar("compositionId", body[0].id);
  }
}
