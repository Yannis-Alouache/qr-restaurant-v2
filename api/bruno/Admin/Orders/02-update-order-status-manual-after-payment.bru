meta {
  name: Update order status (manual after payment)
  type: http
  seq: 2
  tags: [
    admin
    manual
    conditional
  ]
}

patch {
  url: {{baseUrl}}/api/admin/orders/{{adminOrderId}}/status
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "status": "nouvelle"
  }
}
