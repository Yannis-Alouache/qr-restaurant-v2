meta {
  name: Get restaurant
  type: http
  seq: 2
  tags: [
    admin
    smoke
  ]
}

get {
  url: {{baseUrl}}/api/admin/restaurant
  auth: none
}


script:post-response {
  const body = res.getBody();

  if (res.getStatus() === 200) {
    bru.setEnvVar("restaurantId", body.id);
    bru.setEnvVar("restaurantSlug", body.slug);
  }
}
