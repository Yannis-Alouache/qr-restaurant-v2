meta {
  name: Create checkout (requires Stripe configuration)
  type: http
  seq: 1
  tags: [
    public
    conditional
    smoke
  ]
}

post {
  url: {{baseUrl}}/api/public/payments/checkout
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "orderId": "{{orderId}}"
  }
}
