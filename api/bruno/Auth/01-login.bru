meta {
  name: Login
  type: http
  seq: 2
  tags: [
    auth
    smoke
  ]
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{adminEmail}}",
    "password": "{{adminPassword}}"
  }
}

script:post-response {
  const body = res.getBody();

  if (res.getStatus() === 200 && body && body.token) {
    bru.setEnvVar("adminToken", body.token);
  }
}
